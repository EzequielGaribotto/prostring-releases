{
  "name": "qz-tray-installer",
  "version": "1.0.0",
  "description": "Standalone QZ Tray installer for ProString",
  "type": "module",
  "bin": {
    "qz-tray-installer": "./installer.mjs"
  },
  "scripts": {
    "build": "pkg . --targets node18-win-x64,node18-macos-x64,node18-linux-x64 --output dist/install-qz-tray",
    "build:win": "pkg . --targets node18-win-x64 --output dist/install-qz-tray-win.exe",
    "build:macos": "pkg . --targets node18-macos-x64 --output dist/install-qz-tray-macos",
    "build:linux": "pkg . --targets node18-linux-x64 --output dist/install-qz-tray-linux"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "install-qz-tray-windows.ps1",
      "install-qz-tray-unix.sh"
    ],
    "scripts": [
      "installer.mjs"
    ],
    "targets": [
      "node18-win-x64",
      "node18-macos-x64",
      "node18-linux-x64"
    ],
    "outputPath": "dist"
  }
}
