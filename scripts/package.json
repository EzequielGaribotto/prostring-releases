{
  "name": "qz-tray-installer",
  "version": "1.0.0",
  "description": "Standalone QZ Tray installer for ProString",
  "main": "installer.js",
  "bin": {
    "qz-tray-installer": "./installer.js"
  },
  "scripts": {
    "build": "pkg installer.js --targets node16-win-x64,node16-macos-x64,node16-linux-x64 -o dist/install-qz-tray",
    "build:win": "pkg installer.js --targets node16-win-x64 -o dist/install-qz-tray-win.exe",
    "build:macos": "pkg installer.js --targets node16-macos-x64 -o dist/install-qz-tray-macos",
    "build:linux": "pkg installer.js --targets node16-linux-x64 -o dist/install-qz-tray-linux"
  },
  "devDependencies": {
    "pkg": "^5.6.0"
  }
}
